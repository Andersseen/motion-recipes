---
import SiteLayout from '../components/layout/SiteLayout.astro';
import RecipeHero from '../components/catalog/RecipeHero.astro';
import RecipeGrid from '../components/catalog/RecipeGrid.astro';
import { recipes } from '../data/recipes';

const featuredSlugs = new Set(['card-to-modal', 'scroll-reveal', 'view-transition-tabs']);
const featured = recipes.filter((r) => featuredSlugs.has(r.slug));
const latest = [...recipes].reverse();

const categories = [
  { id: 'shared-element', label: 'Shared Element', count: recipes.filter((r) => r.category === 'shared-element').length },
  { id: 'scroll-driven', label: 'Scroll Driven', count: recipes.filter((r) => r.category === 'scroll-driven').length },
  { id: 'view-transitions', label: 'View Transitions', count: recipes.filter((r) => r.category === 'view-transitions').length },
  { id: 'microinteractions', label: 'Microinteractions', count: recipes.filter((r) => r.category === 'microinteractions').length },
  { id: 'text-motion', label: 'Text Motion', count: recipes.filter((r) => r.category === 'text-motion').length },
  { id: 'layout-transitions', label: 'Layout Transitions', count: recipes.filter((r) => r.category === 'layout-transitions').length },
  { id: 'experimental', label: 'Experimental', count: recipes.filter((r) => r.category === 'experimental').length },
];

const whyPoints = [
  { title: 'No runtime dependency', body: 'use CSS, WAAPI and DOM measurements.' },
  { title: 'Better performance', body: 'animate transform and opacity on the compositor.' },
  { title: 'Accessible by default', body: 'respect prefers-reduced-motion and focus.' },
  { title: 'Progressive enhancement', body: 'ship fallbacks for older browsers.' },
];

const reducedMotionSnippet = `@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}`;
---

<SiteLayout title="Motion Recipes">
  <RecipeHero />

  <section class="mr-section" aria-labelledby="featured-title">
    <div class="mr-container">
      <h2 id="featured-title" class="mr-section-title">Featured recipes</h2>
      <p class="mr-section-subtitle">
        Start with these complete examples. Each one includes a live demo, source code and an
        implementation recipe you can follow from scratch.
      </p>
      <RecipeGrid recipes={featured} />
    </div>
  </section>

  <section class="mr-section categories-section" aria-labelledby="categories-title">
    <div class="mr-container">
      <h2 id="categories-title" class="mr-section-title">Categories</h2>
      <p class="mr-section-subtitle">
        Browse patterns by the technique they rely on. Every recipe is framework-agnostic and built
        with native browser APIs.
      </p>
      <ul class="category-grid" role="list">
        {categories.map((cat) => (
          <li>
            <a href={`/recipes/?category=${cat.id}`} class="category-card">
              <and-card variant="outline" padded>
                <span class="category-name">{cat.label}</span>
                <span class="category-count">{cat.count} recipe{cat.count === 1 ? '' : 's'}</span>
              </and-card>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mr-section" aria-labelledby="why-title">
    <div class="mr-container why-grid">
      <div class="why-block">
        <h2 id="why-title" class="mr-section-title">Why browser-native motion?</h2>
        <p class="mr-section-subtitle">
          Modern CSS and JavaScript APIs can deliver fluid, GPU-friendly animation without heavy
          libraries. Native motion tends to be smaller, more performant and easier to make
          accessible.
        </p>
      </div>
      <ul class="why-list" role="list">
        {whyPoints.map((point) => (
          <li>
            <and-card variant="outline" padded>
              <strong>{point.title}</strong> — {point.body}
            </and-card>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mr-section a11y-section" aria-labelledby="a11y-section-title">
    <div class="mr-container a11y-grid">
      <div class="a11y-block">
        <h2 id="a11y-section-title" class="mr-section-title">Accessibility-first animation</h2>
        <p class="mr-section-subtitle">
          Motion should never block content or disorient users. Every recipe in this catalog checks
          reduced motion, keeps keyboard navigation intact and documents focus behavior.
        </p>
      </div>
      <div class="a11y-code">
        <and-code value={reducedMotionSnippet}></and-code>
      </div>
    </div>
  </section>

  <section class="mr-section" aria-labelledby="latest-title">
    <div class="mr-container">
      <h2 id="latest-title" class="mr-section-title">Latest recipes</h2>
      <RecipeGrid recipes={latest} />
    </div>
  </section>
</SiteLayout>

<style>
  .categories-section {
    background: var(--mr-bg-elevated);
    border-block: 1px solid var(--mr-border);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: var(--mr-space-4);
    list-style: none;
    padding: 0;
  }

  .category-card {
    display: block;
    height: 100%;
    text-decoration: none;
    transition: transform var(--mr-duration-fast) var(--mr-ease-out);
  }

  .category-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .category-card:hover {
      transform: none;
    }
  }

  .category-name {
    display: block;
    font-weight: 600;
    color: var(--mr-text-primary);
  }

  .category-count {
    display: block;
    margin-top: var(--mr-space-1);
    font-size: var(--mr-text-sm);
    color: var(--mr-text-muted);
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mr-space-12);
    align-items: start;
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: var(--mr-space-8);
    }
  }

  .why-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--mr-space-4);
    color: var(--mr-text-secondary);
  }

  .why-list strong {
    color: var(--mr-text-primary);
  }

  .a11y-section {
    background: var(--mr-bg-elevated);
    border-block: 1px solid var(--mr-border);
  }

  .a11y-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mr-space-12);
    align-items: center;
  }

  @media (max-width: 768px) {
    .a11y-grid {
      grid-template-columns: 1fr;
      gap: var(--mr-space-8);
    }
  }

  .a11y-code {
    min-width: 0;
  }
</style>
