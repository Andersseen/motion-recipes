---
import type { Recipe } from '../../data/recipes';

export interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;

const categoryLabels: Record<Recipe['category'], string> = {
  'shared-element': 'Shared Element',
  'scroll-driven': 'Scroll Driven',
  'view-transitions': 'View Transitions',
  'microinteractions': 'Microinteractions',
  'text-motion': 'Text Motion',
  'layout-transitions': 'Layout Transitions',
  'experimental': 'Experimental',
};

const difficultyLabel = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
} as const;
---

<and-card variant="outline" padded>
  <div class="recipe-meta">
    <div class="meta-row">
      <span class="meta-label">Category</span>
      <and-badge variant="secondary">{categoryLabels[recipe.category]}</and-badge>
    </div>
    <div class="meta-row">
      <span class="meta-label">Difficulty</span>
      <and-badge variant="secondary">{difficultyLabel[recipe.difficulty]}</and-badge>
    </div>
    <div class="meta-row">
      <span class="meta-label">APIs</span>
      <span class="meta-chips">
        {recipe.APIs.map((api) => (
          <and-badge variant="outline">{api}</and-badge>
        ))}
      </span>
    </div>
    <div class="meta-row">
      <span class="meta-label">Motion</span>
      <span class="meta-badges">
        {recipe.hasReducedMotion && <and-badge>Reduced motion</and-badge>}
        {recipe.hasFallback && <and-badge>Fallback</and-badge>}
      </span>
    </div>
  </div>
</and-card>

<style>
  .recipe-meta {
    display: grid;
    gap: var(--mr-space-4);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--mr-space-3);
  }

  .meta-label {
    min-width: 6rem;
    font-size: var(--mr-text-sm);
    font-weight: 500;
    color: var(--mr-text-muted);
  }

  .meta-chips,
  .meta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mr-space-2);
  }
</style>
