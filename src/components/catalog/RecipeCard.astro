---
import type { Recipe } from '../../data/recipes';

export interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;

const difficultyColor = {
  beginner: '#22c55e',
  intermediate: '#f59e0b',
  advanced: '#ef4444',
} as const;

const categoryLabels: Record<Recipe['category'], string> = {
  'shared-element': 'Shared Element',
  'scroll-driven': 'Scroll Driven',
  'view-transitions': 'View Transitions',
  'microinteractions': 'Microinteractions',
  'text-motion': 'Text Motion',
  'layout-transitions': 'Layout Transitions',
  'experimental': 'Experimental',
};
---

<article class="recipe-card">
  <a href={`/recipes/${recipe.slug}/`} class="card-link" aria-label={`View ${recipe.title} recipe`}>
    <div class="card-header">
      <span class="mr-badge category-badge">{categoryLabels[recipe.category]}</span>
      <span class="difficulty-dot" style={`color: ${difficultyColor[recipe.difficulty]}`} aria-hidden="true"></span>
    </div>
    <h3 class="card-title">{recipe.title}</h3>
    <p class="card-description">{recipe.description}</p>
    <div class="card-meta">
      {recipe.APIs.slice(0, 3).map((api) => (
        <span class="mr-chip">{api}</span>
      ))}
      {recipe.APIs.length > 3 && (
        <span class="mr-chip">+{recipe.APIs.length - 3}</span>
      )}
    </div>
    <div class="card-footer">
      <span class="view-recipe">View recipe</span>
    </div>
  </a>
</article>

<style>
  .recipe-card {
    background: var(--mr-gradient-card);
    border: 1px solid var(--mr-border);
    border-radius: var(--mr-radius-xl);
    overflow: hidden;
    transition: transform var(--mr-duration-base) var(--mr-ease-out),
                box-shadow var(--mr-duration-base) var(--mr-ease-out),
                border-color var(--mr-duration-base) var(--mr-ease-out);
  }

  .recipe-card:hover {
    transform: translateY(-4px);
    border-color: var(--mr-border-strong);
    box-shadow: var(--mr-shadow-lg), 0 0 24px rgba(139, 92, 246, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    .recipe-card {
      transition: none;
    }

    .recipe-card:hover {
      transform: none;
    }
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--mr-space-6);
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--mr-space-5);
  }

  .category-badge {
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .difficulty-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--mr-radius-full);
    background: currentColor;
    box-shadow: 0 0 8px currentColor;
  }

  .card-title {
    font-size: var(--mr-text-xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--mr-space-3);
  }

  .card-description {
    color: var(--mr-text-secondary);
    font-size: var(--mr-text-sm);
    line-height: 1.6;
    margin-bottom: var(--mr-space-5);
    flex: 1;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mr-space-2);
    margin-bottom: var(--mr-space-6);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--mr-space-4);
    border-top: 1px solid var(--mr-border);
  }

  .view-recipe {
    font-size: var(--mr-text-sm);
    font-weight: 500;
    color: var(--mr-accent-light);
  }
</style>
