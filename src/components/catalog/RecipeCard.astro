---
import type { Recipe } from '../../data/recipes';

export interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
const base = import.meta.env.BASE_URL;

const difficultyColor = {
  beginner: '#22c55e',
  intermediate: '#f59e0b',
  advanced: '#ef4444',
} as const;

const categoryLabels: Record<Recipe['category'], string> = {
  'shared-element': 'Shared Element',
  'scroll-driven': 'Scroll Driven',
  'view-transitions': 'View Transitions',
  'microinteractions': 'Microinteractions',
  'text-motion': 'Text Motion',
  'layout-transitions': 'Layout Transitions',
  'experimental': 'Experimental',
};
---

<a href={`${base}recipes/${recipe.slug}/`} class="card-link" aria-label={`View ${recipe.title} recipe`}>
  <and-card variant="elevated" padded>
    <and-card-header>
      <div class="card-header-row">
        <and-badge variant="secondary">{categoryLabels[recipe.category]}</and-badge>
        <span
          class="difficulty-dot"
          style={`color: ${difficultyColor[recipe.difficulty]}`}
          aria-hidden="true"
        ></span>
      </div>
      <and-card-title>{recipe.title}</and-card-title>
    </and-card-header>
    <and-card-content>
      <p class="card-description">{recipe.description}</p>
      <div class="card-meta">
        {recipe.APIs.slice(0, 3).map((api) => (
          <and-badge variant="outline">{api}</and-badge>
        ))}
        {recipe.APIs.length > 3 && (
          <and-badge variant="outline">+{recipe.APIs.length - 3}</and-badge>
        )}
      </div>
    </and-card-content>
    <and-card-footer>
      <span class="view-recipe">
        View recipe
        <and-icon name="arrow-right" size="14"></and-icon>
      </span>
    </and-card-footer>
  </and-card>
</a>

<style>
  .card-link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
  }

  and-card {
    height: 100%;
  }

  .card-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--mr-space-3);
  }

  .difficulty-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--mr-radius-full);
    background: currentColor;
    box-shadow: 0 0 8px currentColor;
  }

  .card-description {
    color: var(--mr-text-secondary);
    font-size: var(--mr-text-sm);
    line-height: 1.6;
    margin-bottom: var(--mr-space-5);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mr-space-2);
  }

  .view-recipe {
    display: inline-flex;
    align-items: center;
    gap: var(--mr-space-2);
    font-size: var(--mr-text-sm);
    font-weight: 500;
    color: var(--mr-accent-light);
  }
</style>
