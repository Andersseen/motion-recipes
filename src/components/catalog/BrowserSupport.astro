---
export interface Props {
  apis: { name: string; support: string; fallback: string }[];
}

const { apis } = Astro.props;
---

<section class="support-section" aria-labelledby="support-title">
  <and-card variant="outline" padded>
    <and-card-header>
      <and-card-title>
        <span class="support-title-inner" id="support-title">
          <and-icon name="layers" size="18"></and-icon>
          Browser support &amp; fallbacks
        </span>
      </and-card-title>
    </and-card-header>
    <and-card-content>
      <div class="support-table-wrapper">
        <table class="support-table">
          <thead>
            <tr>
              <th scope="col">API / Feature</th>
              <th scope="col">Support</th>
              <th scope="col">Fallback strategy</th>
            </tr>
          </thead>
          <tbody>
            {apis.map((api) => (
              <tr>
                <td><code>{api.name}</code></td>
                <td>{api.support}</td>
                <td>{api.fallback}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </and-card-content>
  </and-card>
</section>

<style>
  .support-section {
    margin-top: var(--mr-space-12);
  }

  .support-title-inner {
    display: inline-flex;
    align-items: center;
    gap: var(--mr-space-2);
    color: var(--mr-accent-light);
  }

  .support-table-wrapper {
    overflow-x: auto;
  }

  .support-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--mr-text-sm);
  }

  .support-table th,
  .support-table td {
    padding: var(--mr-space-3) var(--mr-space-4);
    text-align: left;
    border-bottom: 1px solid var(--mr-border);
  }

  .support-table th {
    font-weight: 600;
    color: var(--mr-text-secondary);
    background: var(--mr-bg-elevated);
  }

  .support-table tr:last-child td {
    border-bottom: none;
  }

  .support-table code {
    font-family: var(--mr-font-mono);
    font-size: 0.9em;
    color: var(--mr-accent-light);
  }
</style>
