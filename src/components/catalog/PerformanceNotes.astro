---
export interface Props {
  notes: string[];
}

const { notes } = Astro.props;
---

<section class="notes-section" aria-labelledby="perf-title">
  <and-card variant="outline" padded>
    <and-card-header>
      <and-card-title>
        <span class="notes-title">
          <and-icon name="activity" size="18"></and-icon>
          Performance notes
        </span>
      </and-card-title>
    </and-card-header>
    <and-card-content>
      <ul class="notes-list" id="perf-title">
        {notes.map((note) => (
          <li>{note}</li>
        ))}
      </ul>
    </and-card-content>
  </and-card>
</section>

<style>
  .notes-section {
    margin-top: var(--mr-space-12);
  }

  .notes-title {
    display: inline-flex;
    align-items: center;
    gap: var(--mr-space-2);
    color: var(--mr-accent-light);
  }

  .notes-list {
    padding-left: var(--mr-space-5);
    color: var(--mr-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .notes-list li {
    margin-bottom: var(--mr-space-3);
  }

  .notes-list li::marker {
    color: var(--mr-accent-light);
  }
</style>
