---
import CodeBlock from './CodeBlock.astro';

export interface Props {
  html: string;
  css: string;
  ts: string;
}

const { html, css, ts } = Astro.props;
const tabs = [
  { id: 'html', label: 'HTML', code: html, lang: 'html' as const },
  { id: 'css', label: 'CSS', code: css, lang: 'css' as const },
  { id: 'ts', label: 'TypeScript', code: ts, lang: 'ts' as const },
].filter((tab) => tab.code.trim().length > 0);

const defaultTab = tabs[0]?.id ?? 'html';
---

<and-tabs default-value={defaultTab} class="code-tabs">
  <and-tabs-list>
    {tabs.map((tab) => (
      <and-tabs-trigger value={tab.id}>{tab.label}</and-tabs-trigger>
    ))}
  </and-tabs-list>
  {tabs.map((tab) => (
    <and-tabs-content value={tab.id}>
      <CodeBlock code={tab.code} lang={tab.lang} />
    </and-tabs-content>
  ))}
</and-tabs>

<style>
  .code-tabs {
    display: block;
  }

  and-tabs-content {
    padding-top: var(--mr-space-4);
  }
</style>
