---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../../styles/global.css';
import '@andersseen/layout/dist/layout.css';
import '@andersseen/web-components/dist/web-components/web-components.css';
import '@andersseen/web-components/themes/styles/default.css';
import '@andersseen/web-components/themes/colors/indigo-rose.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A visual catalog of browser-native UI animation patterns.' } = Astro.props;
const pageTitle = title === 'Motion Recipes' ? title : `${title} · Motion Recipes`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-mode="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
    <meta name="theme-color" content="#0a0a0b" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script>
      import '@andersseen/web-components/components/all';
      import { registerAllIcons } from '@andersseen/icon';
      import { enableAnimations } from '@andersseen/web-components';

      registerAllIcons();
      enableAnimations();
    </script>
  </head>
  <body>
    <div class="site-root">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  .site-root {
    min-height: 100dvh;
    display: grid;
    grid-template-rows: auto 1fr auto;
  }
</style>
