---
const navItems = [
  { id: 'recipes', label: 'Recipes', href: '/recipes/' },
  { id: 'about', label: 'About', href: '/#about' },
];

const activeItem = Astro.url.pathname.startsWith('/recipes') ? 'recipes' : '';
---

<and-navbar
  id="main-nav"
  variant="glass"
  position="sticky"
  item-variant="default"
  active-item={activeItem}
  aria-label="Primary"
>
  <a
    slot="brand"
    href="/"
    class="text-fg inline-flex items-center gap-3 font-semibold no-underline hover:no-underline text-[length:var(--mr-text-lg)]"
    aria-label="Motion Recipes home"
  >
    <span
      class="h-7 w-7 rounded-md bg-[linear-gradient(135deg,var(--mr-accent),var(--mr-accent-light))] shadow-[0_0_16px_var(--mr-accent-glow)]"
      aria-hidden="true"
    ></span>
    <span>Motion Recipes</span>
  </a>
</and-navbar>

<script is:inline define:vars={{ navItems, activeItem }}>
  customElements.whenDefined('and-navbar').then(() => {
    const nav = document.getElementById('main-nav');
    nav.items = navItems;
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        nav.activeItem = activeItem;
      });
    });
  });
</script>
